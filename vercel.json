{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "status": 503,
      "dest": "/public/maintenance.html"
    },

    {
      "src": "/api/songByMood",
      "dest": "/api/songByMood.js"
    },
    {
      "src": "/api/search",
      "dest": "/api/search.js"
    },
    {
      "src": "/api/ui",
      "dest": "/api/ui.js"
    },
    {
      "src": "/sw.js",
      "dest": "/public/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/pwa.js",
      "dest": "/public/pwa.js",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/public/normal.html",
      "headers": { "Location": "/normal" },
      "status": 301
    },
    {
      "src": "/public/mood.html",
      "headers": { "Location": "/mood" },
      "status": 301
    },
    {
      "src": "/public/home.html",
      "headers": { "Location": "/" },
      "status": 301
    },
    {
      "src": "/normal",
      "dest": "/public/normal.html"
    },
    {
      "src": "/mood",
      "dest": "/public/mood.html"
    },
    {
      "src": "/",
      "dest": "/public/home.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
